# Core service configuration
OLLAMA_HOST=http://host.docker.internal:11434
FINANCE_DB_URL=https://example-finance-api.local

# Local Postgres defaults used by docker-compose
DB_HOST=db
DB_PORT=5432
DB_NAME=trading_floor
DB_USER=postgres
DB_PASSWORD=change-me

# Optional upstream model provider credentials
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: encrypt TradingAgents provider API keys at rest in DB.
# Set to a long random secret or a 44-char Fernet key.
TA_CONFIG_ENCRYPTION_KEY=change-this-to-a-long-random-secret

# Optional upstream runtime controls
UPSTREAM_MAX_ATTEMPTS=1
# Optional absolute wall-clock caps for the sidecar wrapper (seconds).
# If unset, sidecar timeout is derived from per-attempt timeout * max attempts + 120s buffer.
UPSTREAM_RUN_TIMEOUT_SECONDS_QUICK=5520
UPSTREAM_RUN_TIMEOUT_SECONDS_STANDARD=8220
UPSTREAM_RUN_TIMEOUT_SECONDS_DEEP=12600
UPSTREAM_TIMEOUT_SECONDS_QUICK=2400
UPSTREAM_TIMEOUT_SECONDS_STANDARD=3300
UPSTREAM_TIMEOUT_SECONDS_DEEP=4800
UPSTREAM_STALL_TIMEOUT_SECONDS_QUICK=900
UPSTREAM_STALL_TIMEOUT_SECONDS_STANDARD=1200
UPSTREAM_STALL_TIMEOUT_SECONDS_DEEP=1800
